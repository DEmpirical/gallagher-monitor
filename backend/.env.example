# Gallagher Command Centre connection
GALLAGHER_HOST=https://your-gallagher-server:8443
GALLAGHER_API_KEY=your-api-key-here

# Optional: Client certificate for mutual TLS (if required by Gallagher)
# GALLAGHER_CLIENT_CERT=/path/to/client.crt
# GALLAGHER_CLIENT_KEY=/path/to/client.key
# GALLAGHER_CA_CERT=/path/to/ca.crt

# Backend server
PORT=3001
NODE_ENV=development

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Internal token for frontend-backend auth
INTERNAL_TOKEN=change-me

# Polling config (for fallback if updates not supported)
POLL_INTERVAL_MS=30000
REQUEST_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
