# Gallagher Command Centre connection
GALLAGHER_HOST=192.168.1.78
GALLAGHER_PORT=8443
GALLAGHER_API_KEY=GGL-API-KEY-here
GALLAGHER_CLIENT_CERT_THUMBPRINT=8e99a51f3c5a9e20258e9610345507bbea00abfb
